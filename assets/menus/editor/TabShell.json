{
  "menus": [
    {
      "id": "TabShell",
      "raycast_input": true,
      "elements": [
        {
          "id": "tab_bar",
          "type": "sprite",
          "anchor": "top_left",
          "pivot": "top_left",
          "position": {"x": "0%", "y": "0%"},
          "size": {"x": "100%", "y": "32px"},
          "color": [1.0, 1.0, 1.0, 1.0]
        },
        {
          "id": "tab_canvas",
          "type": "canvas_area",
          "anchor": "top_left",
          "pivot": "top_left",
          "position": {"x": "0%", "y": "32px"},
          "size": {"x": "100%", "y": "calc(100% - 32px)"}
        }
      ]
    }
  ]
}