{
  "menus": [
    {
      "id": "TabShell",
      "raycast_input": true,
      "elements": [
        {
          "id": "window_frame",
          "type": "sprite",
          "sprite": "menus/EditorTab",
          "anchor": "top_left",
          "pivot": "top_left",
          "position": {"x": "0%", "y": "0%"},
          "size": {"x": "100%", "y": "100%"},
          "color": [1.0, 1.0, 1.0, 1.0]
        },
        {
          "id": "tab_canvas",
          "type": "canvas_area",
          "anchor": "center",
          "pivot": "center",
          "position": {"x": "0px", "y": "11.5px"},
          "size": {"x": "calc(100% - 10px)", "y": "calc(100% - 33px)"}
        }
      ]
    }
  ]
}