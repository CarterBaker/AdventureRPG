{
  "elements": [
    {
      "id": "testing_dropdown_panel",
      "type": "container",
      "anchor": "bottom_left",
      "pivot": "bottom_left",
      "size": {"x": "150px", "y": "56px"},
      "elements": [
        {
          "id": "testing_dropdown_content",
          "type": "container",
          "anchor": "top_left",
          "pivot": "bottom_left",
          "size": {"x": "150px", "y": "56px"},
          "stack": "vertical",
          "font_size": "50%",
          "sprite": "menus/DefaultElement",
          "elements": [
            {
              "id": "open_window_button",
              "type": "button",
              "sprite": "menus/DefaultElement",
              "size": {"x": "150px", "y": "28px"},
              "on_click": {
                "class": "editor.runtime.editor.menueventsmanager.menus.EditorBranch",
                "method": "openSecondaryWindow"
              },
              "elements": [
                {
                  "id": "open_window_label",
                  "type": "label",
                  "text": "Open Window",
                  "color": [0, 0, 0, 1]
                }
              ]
            },
            {
              "id": "open_preview_button",
              "type": "button",
              "sprite": "menus/DefaultElement",
              "size": {"x": "150px", "y": "28px"},
              "on_click": {
                "class": "editor.runtime.editor.menueventsmanager.menus.EditorBranch",
                "method": "openPreview"
              },
              "elements": [
                {
                  "id": "open_preview_label",
                  "type": "label",
                  "text": "Open Preview",
                  "color": [0, 0, 0, 1]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "menus": [
    {
      "id": "Base",
      "elements": [
        {
          "id": "background",
          "type": "sprite",
          "anchor": "top_left",
          "pivot": "bottom_left",
          "size": {"x": "100%", "y": "100%"},
          "sprite": "util/Default",
          "color": [0.13, 0.13, 0.13, 1.0]
        },
        {
          "id": "dock_canvas",
          "type": "canvas_area",
          "anchor": "bottom_left",
          "pivot": "top_left",
          "size": {"x": "100%", "y": "calc(100% - 28px)"}
        }
      ]
    },
    {
      "id": "Toolbar",
      "raycast_input": true,
      "lock_input": true,
      "elements": [
        {
          "id": "toolbar",
          "use": "util/ToolBar",
          "elements": [
            {
              "id": "testing_menu",
              "type": "container",
              "anchor": "top_left",
              "pivot": "bottom_left",
              "size": {"x": "100px", "y": "28px"},
              "elements": [
                {
                  "id": "testing_button_bg",
                  "type": "container",
                  "anchor": "top_left",
                  "pivot": "bottom_left",
                  "size": {"x": "100px", "y": "28px"},
                  "elements": [
                    {
                      "id": "testing_bg_label",
                      "type": "label",
                      "text": "Testing",
                      "font_size": "50%",
                      "color": [0, 0, 0, 1]
                    }
                  ]
                },
                {
                  "id": "testing_button",
                  "type": "button",
                  "anchor": "top_left",
                  "pivot": "bottom_left",
                  "size": {"x": "100px", "y": "28px"},
                  "on_hover_enter": {
                    "use": "editor/EditorWindow/testing_dropdown_panel"
                  },
                  "on_hover_exit": {}
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "Secondary",
      "raycast_input": true,
      "lock_input": true,
      "elements": [
        {
          "id": "toolbar",
          "use": "util/ToolBar"
        },
        {
          "id": "dock_canvas",
          "type": "canvas_area",
          "anchor": "bottom_left",
          "pivot": "top_left",
          "size": {"x": "100%", "y": "calc(100% - 28px)"}
        }
      ]
    }
  ]
}