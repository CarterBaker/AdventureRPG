{
  "elements": [
    {
      "id": "testing_dropdown_panel",
      "type": "container",
      "anchor": "bottom_left",
      "pivot": "bottom_left",
      "size": {"x": "150px", "y": "56px"},
      "stack": "vertical",
      "elements": [
        {
          "id": "open_window_button",
          "type": "button",
          "size": {"x": "150px", "y": "28px"},
          "on_click": {
            "class": "editor.runtime.editor.menueventsmanager.menus.EditorBranch",
            "method": "openSecondaryWindow"
          },
          "elements": [
            {
              "id": "open_window_label",
              "type": "label",
              "text": "Open Window"
            }
          ]
        },
        {
          "id": "open_preview_button",
          "type": "button",
          "size": {"x": "150px", "y": "28px"},
          "on_click": {
            "class": "editor.runtime.editor.menueventsmanager.menus.EditorBranch",
            "method": "openPreview"
          },
          "elements": [
            {
              "id": "open_preview_label",
              "type": "label",
              "text": "Open Preview"
            }
          ]
        }
      ]
    }
  ],
  "menus": [
    {
      "id": "Base",
      "elements": [
        {
          "id": "background",
          "type": "sprite",
          "anchor": "top_left",
          "pivot": "bottom_left",
          "size": {"x": "100%", "y": "100%"},
          "sprite": "util/Default",
          "color": [0.13, 0.13, 0.13, 1.0]
        },
        {
          "id": "dock_canvas",
          "type": "canvas_area",
          "anchor": "bottom_left",
          "pivot": "top_left",
          "size": {"x": "100%", "y": "calc(100% - 28px)"}
        }
      ]
    },
    {
      "id": "Toolbar",
      "raycast_input": true,
      "lock_input": true,
      "entry_points": ["testing_dropdown"],
      "elements": [
        {
          "id": "toolbar",
          "use": "util/ToolBar",
          "elements": [
            {
              "id": "testing_menu",
              "type": "container",
              "anchor": "top_left",
              "pivot": "bottom_left",
              "size": {"x": "100px", "y": "28px"},
              "elements": [
                {
                  "id": "testing_button",
                  "type": "button",
                  "anchor": "top_left",
                  "pivot": "bottom_left",
                  "size": {"x": "100px", "y": "28px"},
                  "on_click": {
                    "class": "editor.runtime.editor.menueventsmanager.menus.EditorBranch",
                    "method": "toggleTestingDropdown",
                    "arg": "$parent"
                  },
                  "elements": [
                    {
                      "id": "testing_label",
                      "type": "label",
                      "text": "Testing"
                    }
                  ]
                },
                {
                  "id": "testing_dropdown",
                  "type": "container",
                  "anchor": "top_left",
                  "pivot": "bottom_left",
                  "size": {"x": "100px", "y": "28px"},
                  "start_expanded": false,
                  "hover_state": {
                    "use": "editor/EditorWindow/testing_dropdown_panel"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "Secondary",
      "raycast_input": true,
      "lock_input": true,
      "elements": [
        {
          "id": "toolbar",
          "use": "util/ToolBar"
        },
        {
          "id": "dock_canvas",
          "type": "canvas_area",
          "anchor": "bottom_left",
          "pivot": "top_left",
          "size": {"x": "100%", "y": "calc(100% - 28px)"}
        }
      ]
    }
  ]
}