{
    "elements": [
        {
            "id":     "close",
            "type":   "button",
            "sprite": "menus/DebugElement",
            "anchor": "CENTER",
            "pivot":  "CENTER",
            "on_click": {
                "class":  "application.bootstrap.menupipeline.menueventsmanager.menus.MainMenuBranch",
                "method": "closeMenu",
                "arg":    "$parent"
            },
            "elements": [
                {
                    "id":     "closeLabel",
                    "type":   "label",
                    "font":   "MontserratAlternates",
                    "text":   "Close",
                    "color":  [0, 0, 0, 1],
                    "anchor": "CENTER",
                    "pivot":  "CENTER",
                    "size":   { "x": "100%", "y": "100%" }
                }
            ]
        },
        {
            "id":   "title",
            "type": "sprite",
            "sprite": "menus/Title",
            "anchor": "TOP_CENTER",
            "pivot":  "TOP_CENTER",
            "position": { "x": "0%",  "y": "-5%" },
            "size":     { "x": "40%", "y": "20%" },
            "min_size": { "x": "300px", "y": "80px" }
        }
    ],
    "menus": [
        {
            "id":            "Main",
            "lock_input":    true,
            "raycast_input": true,
            "elements": [
                {
                    "id":  "title",
                    "ref": "MainMenu/title"
                },
                {
                    "id":       "empty",
                    "use":      "util/Containers",
                    "anchor":   "CENTER",
                    "pivot":    "CENTER",
                    "position": { "x": "0%",  "y": "0%"  },
                    "size":     { "x": "20%", "y": "10%" },
                    "elements": [
                        {
                            "id":       "close",
                            "ref":      "MainMenu/close",
                            "anchor":   "CENTER",
                            "pivot":    "CENTER",
                            "position": { "x": "0%", "y": "60%" },
                            "size":     { "x": "80%", "y": "60%" }
                        },
                        {
                            "id":       "quit",
                            "use":      "util/GenericButtons",
                            "anchor":   "CENTER",
                            "pivot":    "CENTER",
                            "position": { "x": "0%", "y": "0%"  },
                            "size":     { "x": "80%", "y": "60%" },
                            "elements": [
                                {
                                    "id":     "quitLabel",
                                    "type":   "label",
                                    "font":   "MontserratAlternates",
                                    "text":   "Quit",
                                    "color":  [0, 0, 0, 1],
                                    "anchor": "CENTER",
                                    "pivot":  "CENTER",
                                    "size":   { "x": "100%", "y": "100%" }
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
